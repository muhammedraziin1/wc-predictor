# Copy this file to ".env" (same folder) and fill in your real values.
# Find these in Supabase: Project Settings → API.
# The anon key is safe to expose in a front-end app; do NOT use the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
